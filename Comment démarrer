Colle ces requêtes une par une dans l'Éditeur de requête Azure :
1. Utilisateurs :
sql
SELECT id, prenom, nom, email, telephone, 
       departement, statut, date_creation
FROM Utilisateurs
ORDER BY id;
2. Agents :
sql
SELECT id, prenom, nom, email, specialite, 
       niveau, tickets_resolus, note_moyenne, disponible
FROM Agents
ORDER BY id;
3. Tickets :
sql
SELECT 
    t.id, t.reference, t.titre, t.categorie,
    t.priorite, t.statut,
    u.prenom + ' ' + u.nom AS utilisateur,
    a.prenom + ' ' + a.nom AS agent,
    t.date_creation, t.date_resolution
FROM Tickets t
LEFT JOIN Utilisateurs u ON u.id = t.utilisateur_id
LEFT JOIN Agents a ON a.id = t.agent_id
ORDER BY t.date_creation DESC;
4. Historique des tickets :
sql
SELECT 
    h.id, t.reference,
    h.auteur_type, h.action,
    h.ancien_statut, h.nouveau_statut,
    h.commentaire, h.date_action
FROM HistoriqueTickets h
JOIN Tickets t ON t.id = h.ticket_id
ORDER BY h.date_action DESC;
5. Commentaires :
sql
SELECT 
    c.id, t.reference,
    c.auteur_type, c.contenu,
    c.interne, c.date_creation
FROM Commentaires c
JOIN Tickets t ON t.id = c.ticket_id
ORDER BY c.date_creation DESC;
6. Notifications :
sql
SELECT 
    n.id, n.destinataire_type,
    n.destinataire_id, t.reference,
    n.type, n.message, n.lue,
    n.date_creation
FROM Notifications n
LEFT JOIN Tickets t ON t.id = n.ticket_id
ORDER BY n.date_creation DESC;
7. Vue globale — tout en une seule requête :
sql
SELECT 
    t.reference,
    t.titre,
    t.priorite,
    t.statut,
    t.categorie,
    u.prenom + ' ' + u.nom AS utilisateur,
    u.email AS email_utilisateur,
    a.prenom + ' ' + a.nom AS agent,
    a.specialite,
    COUNT(DISTINCT c.id) AS nb_commentaires,
    COUNT(DISTINCT h.id) AS nb_historique,
    t.date_creation,
    t.date_resolution
FROM Tickets t
LEFT JOIN Utilisateurs u ON u.id = t.utilisateur_id
LEFT JOIN Agents a ON a.id = t.agent_id
LEFT JOIN Commentaires c ON c.ticket_id = t.id
LEFT JOIN HistoriqueTickets h ON h.ticket_id = t.id
GROUP BY 
    t.reference, t.titre, t.priorite, t.statut, t.categorie,
    u.prenom, u.nom, u.email,
    a.prenom, a.nom, a.specialite,
    t.date_creation, t.date_resolution
ORDER BY t.date_creation DESC;


















